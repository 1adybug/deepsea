{
    "compilerOptions": {
        "rootDir": "src",
        "strict": true,
        "declaration": true,
        "skipLibCheck": true,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "verbatimModuleSyntax": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src"]
}
