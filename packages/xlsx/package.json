{
	"name": "@1adybug/xlsx",
	"version": "0.20.3",
	"author": "sheetjs",
	"description": "SheetJS Spreadsheet data parser and writer",
	"keywords": [
		"excel",
		"xls",
		"xlsx",
		"xlsb",
		"xlsm",
		"ods",
		"csv",
		"dbf",
		"dif",
		"sylk",
		"office",
		"spreadsheet"
	],
	"bin": {
